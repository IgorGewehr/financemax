# OpenAI (Super Consultor) — pegue do seu provedor
OPENAI_API_KEY=sk-...
OPENAI_MODEL_DEFAULT=gpt-4o-mini
# Porta do HOST (container é sempre 8080 interno)
FINANCEMAX_HOST_PORT=8090
# Segredo do JWT (>=32 chars) — gere com: openssl rand -hex 32
FINANCEMAX_JWT_SECRET=troque-por-um-segredo-de-32+-caracteres-aleatorios
# Admin inicial (troca a senha no 1o login)
FINANCEMAX_ADMIN_EMAIL_INICIAL=admin@financemax.local
FINANCEMAX_ADMIN_SENHA_INICIAL=troque-esta-senha
# Cloudflare Tunnel (opcional, p/ acesso online do colega) — docker compose --profile tunnel up
CLOUDFLARE_TUNNEL_TOKEN=
# Origens liberadas no CORS (csv) — o web dev (5173) e o Tauri já vêm no default; a URL do túnel entra aqui em produção
FINANCEMAX_CORS_ORIGINS=http://localhost:5173,tauri://localhost,https://tauri.localhost
