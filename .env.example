OPENAI_API_KEY=sk-...
OPENAI_MODEL_DEFAULT=gpt-4o-mini

# server (financemax-api). Single-tenant fixo (1 negócio, N usuários — MVP-ESCOPO.md).
FINANCEMAX_PORT=8080
FINANCEMAX_BUSINESS_ID=dev-tenant

# F2 — auth e-mail+senha multi-usuário (ARQUITETURA.md §3). NUNCA use este valor de exemplo em
# produção — gere um segredo forte com `openssl rand -base64 48` e cole aqui (32+ caracteres,
# o servidor recusa subir com menos). Trocar este valor revoga TODOS os refresh tokens emitidos.
FINANCEMAX_JWT_SECRET=troque-por-openssl-rand-base64-48-antes-de-subir-em-producao
# Opcionais — os defaults (15min access / 30 dias refresh) já são os recomendados.
# FINANCEMAX_JWT_ACCESS_MINUTOS=15
# FINANCEMAX_JWT_REFRESH_DIAS=30
# FINANCEMAX_LOGIN_RATE_LIMIT_PERMIT=10

# Bootstrap do usuário administrador inicial (roda uma única vez, no primeiro boot — idempotente).
# Deixe FINANCEMAX_ADMIN_SENHA_INICIAL em branco/comentado para o servidor GERAR uma senha
# aleatória forte e logá-la (uma única vez, no console) — recomendado. Preencha aqui só se você
# quer uma senha inicial CONHECIDA (ex.: ambiente de dev reproducível).
# FINANCEMAX_ADMIN_EMAIL_INICIAL=admin@financemax.local
# FINANCEMAX_ADMIN_SENHA_INICIAL=

# Cloudflare Tunnel — acesso ONLINE do colega, sem abrir porta (README.md "Acesso remoto").
# Gere o token no painel Cloudflare Zero Trust > Networks > Tunnels > (seu túnel) > Configure.
# Só é usado se você subir com `docker compose --profile tunnel up`. NUNCA commite o valor real.
CLOUDFLARE_TUNNEL_TOKEN=
