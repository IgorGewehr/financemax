# Base URL absoluta do Financemax.Api (F2/F1 — servidor .NET em /Users/igorgewehr/air/financemax/server).
# O client (lib/api/client.ts) sempre bate em `${VITE_API_BASE_URL}/api/...`.
#
# Dev local (server rodando via docker-compose/dotnet run em :8080):
VITE_API_BASE_URL=http://localhost:8080

