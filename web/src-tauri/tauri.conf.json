{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "financemax",
  "version": "0.1.0",
  "identifier": "com.financemax.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "financemax",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "financemax",
    "shortDescription": "financemax — dashboard financeiro desktop",
    "longDescription": "App desktop do financemax (Financeiro do SistemaX standalone): DRE, fluxo de caixa, runway, breakeven e Radar do Simples Nacional, conectado ao Financemax.Api via VITE_API_BASE_URL.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
